<Window x:Class="GestorDeProductos.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestorDeProductos"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TabControl>
            <TabItem Header="INVENTARIO">
                <Grid Background="#FFD4C2AD">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="103*"/>
                        <ColumnDefinition Width="37*"/>
                        <ColumnDefinition Width="65*"/>
                        <ColumnDefinition Width="589*"/>
                    </Grid.ColumnDefinitions>
                    <DataGrid x:Name="dataGridProducto" d:ItemsSource="{d:SampleData ItemCount=5}" Grid.ColumnSpan="4" Background="#FFD4C2AD"/>
                    <Button x:Name="btnAgregar" Content="Agregar" HorizontalAlignment="Left" Margin="32,167,0,0" VerticalAlignment="Top" Height="36" Width="82" Grid.ColumnSpan="2" Background="White" Grid.Column="2"/>
                    <Button x:Name="btnEliminar" Content="Eliminar" Margin="0,162,237,0" VerticalAlignment="Top" Height="36" Grid.Column="3" Background="White" HorizontalAlignment="Right" Width="82"/>
                </Grid>
            </TabItem>
            <TabItem Header="BUSQUEDA">
                <Grid Background="#FFAFC3D5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="25*"/>
                        <ColumnDefinition Width="149*"/>
                        <ColumnDefinition Width="29*"/>
                        <ColumnDefinition Width="591*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="comboTipoBusqueda" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="774" Grid.ColumnSpan="4" Height="42"/>
                    <TextBox x:Name="txtBusqueda" HorizontalAlignment="Left" Margin="12,86,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="772" Grid.ColumnSpan="4" Height="46"/>
                    <TextBlock x:Name="txtResultadoBusqueda" HorizontalAlignment="Left" Margin="12,239,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top" Grid.ColumnSpan="4" Height="41" Width="772"/>
                    <Button x:Name="btnBuscar" Content="Buscar" HorizontalAlignment="Left" Margin="10,167,0,0" VerticalAlignment="Top" Height="36" Width="82" Background="White" Grid.Column="1"/>
                    <ProgressBar x:Name="iteraciones" Grid.Column="3" HorizontalAlignment="Left" Height="22" Margin="24,174,0,0" VerticalAlignment="Top" Width="455"/>
                </Grid>
            </TabItem>
            <TabItem Header="ORDENAMIENTO">
                <Grid Background="#FFCBBED9">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="63*"/>
                        <ColumnDefinition Width="334*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="comboCriterioOrden" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="774" Height="42" Grid.ColumnSpan="2"/>
                    <Button x:Name="btnOrdenar" Content="Ordenar" HorizontalAlignment="Left" Margin="34,72,0,0" VerticalAlignment="Top" Height="36" Width="82" Background="White"/>
                    <ListView x:Name="listViewOrdenados" d:ItemsSource="{d:SampleData ItemCount=5}" Grid.ColumnSpan="2" Margin="10,134,412,10">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <Canvas Grid.Column="1" Margin="290,134,10,10">
                        <Rectangle Height="202" Canvas.Left="10" Stroke="Black" Canvas.Top="50" Width="35"/>
                    </Canvas>
                </Grid>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
