<Window x:Class="GestorDeProductos.WindowAgregarProductoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestorDeProductos"
        mc:Ignorable="d"
        Title="WindowAgregarProductoWindow" Height="450" Width="800">
    <Grid Background="#FFBDD5B4">
        <Button x:Name="txtID" Content="ID" HorizontalAlignment="Left" Margin="22,22,0,0" VerticalAlignment="Top" Height="36" Width="105" Background="White"/>
        <Button x:Name="txtCodigoBarras" Content="Codigo de Barras" HorizontalAlignment="Left" Margin="22,79,0,0" VerticalAlignment="Top" Height="36" Width="104" Background="White"/>
        <Button x:Name="txtNombre" Content="Nombre" HorizontalAlignment="Left" Margin="22,133,0,0" VerticalAlignment="Top" Height="36" Width="105" Background="White"/>
        <Button x:Name="txtCategoria" Content="Categoria" HorizontalAlignment="Left" Margin="22,187,0,0" VerticalAlignment="Top" Height="36" Width="105" Background="White"/>
        <Button x:Name="txtPrecio" Content="Precio" HorizontalAlignment="Left" Margin="22,243,0,0" VerticalAlignment="Top" Height="36" Width="105" Background="White"/>
        <Button x:Name="txtStock" Content="Stock" HorizontalAlignment="Left" Margin="22,298,0,0" VerticalAlignment="Top" Height="36" Width="105" Background="White"/>
        <Button x:Name="btnGuardar" Content="Guardar" HorizontalAlignment="Left" Margin="22,357,0,0" VerticalAlignment="Top" Height="54" Width="157" Background="White"/>
    </Grid>
</Window>
